# Явно объявляем текстовые файлы с LF
*.go text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
